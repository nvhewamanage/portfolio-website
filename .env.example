# ─── Server ────────────────────────────────────────────────────
PORT=3000

# ─── Firebase ──────────────────────────────────────────────────
# OPTION A (local file): place firebase-service-account.json in project root
#   → Go to Firebase Console → Project Settings → Service Accounts
#   → Click "Generate new private key" → rename to firebase-service-account.json
#   → Add firebase-service-account.json to your .gitignore!
#
# OPTION B (env variable): paste your entire service-account JSON as one line:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}

# ─── Admin Account ─────────────────────────────────────────────
# Created automatically on first startup if no admin exists in Firestore
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── JWT (change this to a long random string in production!) ──
JWT_SECRET=change_me_to_a_long_random_secret_string

# ─── Gmail (for contact form + newsletter) ─────────────────────
# Your Gmail address:
GMAIL_USER=yourname@gmail.com
# Gmail App Password (16 chars, NOT your login password):
# Get it: myaccount.google.com → Security → 2-Step Verification → App Passwords
GMAIL_PASS=xxxx xxxx xxxx xxxx

# ─── Site URL (used in welcome email link) ─────────────────────
SITE_URL=http://localhost:3000
